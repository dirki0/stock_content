    "db:migrate": "drizzle-kit migrate --config ./server/db/drizzle.config.ts"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.4.9",
    "@nuxt/eslint": "1.10.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/i18n": "10.2.1",
    "@polar-sh/better-auth": "^1.6.3",
    "@polar-sh/sdk": "^0.42.1",
    "@vueuse/core": "^14.1.0",
    "@vueuse/nuxt": "^14.1.0",
    "better-auth": "^1.4.9",
    "consola": "^3.4.2",
    "drizzle-orm": "^0.45.1",
    "nuxt": "catalog:",
    "pg": "^8.16.3",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vue": "catalog:",
    "vue-tsc": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config": "workspace:*"
  }
