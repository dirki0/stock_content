{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        ".vercel/output/**",
        "dist/**",
        ".output/**",
        ".nuxt/**"
      ]
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "lint:fix": {
      "outputs": [],
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["dev:prepare"]
    },
    "dev:prepare": {
      "outputs": [
        "dist/**",
        ".output/**",
        ".nuxt/**"
      ],
      "cache": false
    },
    "typecheck": {
      "cache": true
    },
    "db:studio": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "test:e2e": {
      "cache": false
    },
    "test:e2e:ui": {
      "cache": false
    }
  },
  "globalEnv": [
    "POLAR_ACCESS_TOKEN",
    "POLAR_SERVER"
  ]
}
