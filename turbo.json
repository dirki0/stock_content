{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "lint:fix": {
      "outputs": []
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["dev:prepare"]
    },
    "dev:prepare": {
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  },
  "globalEnv": [
    "POLAR_ACCESS_TOKEN",
    "POLAR_SERVER"
  ]
}
