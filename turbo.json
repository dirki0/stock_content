{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": [
        ".vercel/output/**",
        "dist/**",
        ".output/**",
        ".nuxt/**"
      ]
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "lint:fix": {
      "outputs": [],
      "cache": false
    },
    "dev": {
      "persistent": true,
      "cache": false,
      "dependsOn": ["dev:prepare"]
    },
    "dev:prepare": {
      "outputs": [
        "dist/**",
        ".output/**",
        ".nuxt/**"
      ],
      "cache": false
    },
    "typecheck": {
      "cache": true
    },
    "db:studio": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "test:e2e": {
      "cache": false
    },
    "test:e2e:ui": {
      "cache": false
    }
  },
  "globalEnv": [
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "DATABASE_NAME",
    "DATABASE_PASSWORD",
    "DATABASE_USER",
    "GITHUB_ACTIONS",
    "NUXT_PRIVATE_DATABASE_URL",
    "NUXT_PRIVATE_EMAIL_CONTACT",
    "NUXT_PRIVATE_EMAIL_PLUNK_API_KEY",
    "NUXT_PRIVATE_EMAIL_PLUNK_API_URL",
    "NUXT_PRIVATE_EMAIL_PROVIDER",
    "NUXT_PRIVATE_EMAIL_SEND_IN_DEV_MODE",
    "NUXT_PRIVATE_FROM_EMAIL",
    "NUXT_PRIVATE_GITHUB_CLIENT_ID",
    "NUXT_PRIVATE_GITHUB_CLIENT_SECRET",
    "NUXT_PRIVATE_GOOGLE_CLIENT_ID",
    "NUXT_PRIVATE_GOOGLE_CLIENT_SECRET",
    "NUXT_PRIVATE_POLAR_ACCESS_TOKEN",
    "NUXT_PRIVATE_POLAR_ORGANIZATION_ID",
    "NUXT_PRIVATE_POLAR_SERVER",
    "NUXT_PRIVATE_REDIS_URL",
    "NUXT_PRIVATE_STORAGE_LOCAL_PUBLIC_PATH",
    "NUXT_PRIVATE_STORAGE_PROVIDER",
    "NUXT_PRIVATE_STORAGE_S3_ACCESS_KEY_ID",
    "NUXT_PRIVATE_STORAGE_S3_BUCKET_NAME",
    "NUXT_PRIVATE_STORAGE_S3_ENDPOINT",
    "NUXT_PRIVATE_STORAGE_S3_PUBLIC_URL",
    "NUXT_PRIVATE_STORAGE_S3_REGION",
    "NUXT_PRIVATE_STORAGE_S3_SECRET_ACCESS_KEY",
    "NUXT_PRIVATE_STORAGE_UPLOAD_DIR",
    "NUXT_PUBLIC_ADMIN_DEMO_MODE_ENABLED",
    "NUXT_PUBLIC_BASE_URL",
    "NUXT_UMAMI_HOST",
    "NUXT_UMAMI_ID",
    "POLAR_ACCESS_TOKEN",
    "POLAR_SERVER"
  ]
}
